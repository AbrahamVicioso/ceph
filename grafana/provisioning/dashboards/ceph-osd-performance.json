    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "custom": {
            "displayMode": "color-background"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "up" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "in" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "OUT", "color": "orange" }, "1": { "text": "IN", "color": "green" } } }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 42,
      "options": {
        "footer": { "show": false },
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "ceph_daemon" }]
      },
      "title": "Estado de OSDs",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ceph_osd_up",
          "instant": true,
          "legendFormat": "{{ceph_daemon}}",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "ceph_osd_in",
          "instant": true,
          "legendFormat": "{{ceph_daemon}}",
          "format": "table"
        }
      ],
      "type": "table",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        }
      ]
